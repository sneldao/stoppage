FROM node:20-slim AS builder

WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/web/package.json apps/web/package.json
COPY apps/agent/package.json apps/agent/package.json
COPY packages/sdk/package.json packages/sdk/package.json
COPY packages/txline/package.json packages/txline/package.json
RUN npm ci

COPY . .

# These values are deliberately build arguments: Next embeds NEXT_PUBLIC_*
# values into the browser bundle.
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_HELIUS_RPC_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL \
    NEXT_PUBLIC_HELIUS_RPC_URL=$NEXT_PUBLIC_HELIUS_RPC_URL

RUN npm run build --workspace=@stoppage/web

FROM node:20-slim AS runner

WORKDIR /app
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0

RUN groupadd --system --gid 1001 nodejs \
  && useradd --system --uid 1001 --gid nodejs nextjs

COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs
EXPOSE 3000

CMD ["node", "apps/web/server.js"]
