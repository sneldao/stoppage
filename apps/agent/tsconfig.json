{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@stoppage/sdk": ["../../packages/sdk/src/index.ts"],
      "@stoppage/txline": ["../../packages/txline/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
