# Copy to .env.local and fill in.
#
# NOTE (lesson from pir8): program IDs are deliberately NOT env vars here.
# They live in packages/sdk/src/programIds.ts, generated from keys/ by
# scripts/sync-ids.js and enforced by `npm run check:ids`. One source of
# truth, zero copy-paste drift.

# Helius RPC (https URL; the WebSocket URL is derived from it)
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Public app URL (used for wallet app-identity and Blinks icons)
NEXT_PUBLIC_APP_URL=http://localhost:3000
