# Keep this file on the VPS as /home/linuxuser/stoppage/.env.agent (mode 600).
TXLINE_NETWORK=devnet
TXLINE_JWT=replace-me
TXLINE_API_TOKEN=replace-me
SOLANA_KEYPAIR_PATH=/home/linuxuser/stoppage/secrets/agent-devnet.json
MATCH_EVENTS_PATH=/home/linuxuser/stoppage/.runtime/match-events.ndjson
AGENT_HTTP_PORT=18766

# OpenTelemetry → SigNoz (optional; see docs/OBSERVABILITY.md)
# Install SigNoz on the VPS: ./scripts/install-signoz-vps.sh
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=stoppage-agent
# OTEL_METRIC_EXPORT_INTERVAL_MS=10000
