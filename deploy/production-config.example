# Public values. NEXT_PUBLIC_* values are embedded in the web bundle.
NEXT_PUBLIC_APP_URL=https://stoppage.example.com
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY
STOPPAGE_DOMAIN=stoppage.example.com

# Server-only TxLINE credentials for /api/fixtures.
TXLINE_NETWORK=devnet
TXLINE_JWT=replace-me
TXLINE_API_TOKEN=replace-me

# Optional server-only RPC key for public board scans.
SHYFT_API_KEY=replace-me

# Read-only path inside the web container. Docker Compose mounts the host ledger here.
MATCH_EVENTS_PATH=/app/.runtime/match-events.ndjson
